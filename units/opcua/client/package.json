{
  "scripts": {
    "build": "npm run build:js && npm run build:python",
    "build:js": "esbuild --bundle src/*/index.tsx --external:pr1 --external:react --format=esm --outbase=src --outdir=dist",
    "build:python": "python3 -c \"for d in __import__('pathlib').Path('dist').glob('*'): (d / '__init__.py').open('w')\""
  },
  "devDependencies": {
    "@types/react": "^18.0.16",
    "esbuild": "^0.14.53",
    "pr1": "file:../../../client"
  }
}
