{
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:python",
    "build:css": "sass styles:dist --no-source-map",
    "build:js": "python3 -c \"__import__('os').system(f'''esbuild --bundle {' '.join(__import__('glob').glob('src/*/index.*'))} --external:*.css --external:pr1 --external:react --format=esm --outbase=src --outdir=dist ''' + ' '.join(__import__('sys').argv[1:]))\"",
    "build:python": "python3 -c \"for d in __import__('pathlib').Path('dist').glob('*'): (d / '__init__.py').open('w')\""
  },
  "dependencies": {
    "immutable": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.16",
    "esbuild": "^0.14.53",
    "pr1": "file:../../../client",
    "sass": "^1.54.4"
  }
}
